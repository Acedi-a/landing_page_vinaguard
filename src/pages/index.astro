---
import TopNotificationBar from '../components/sections/TopNotificationBar.astro';
import NavigationBar from '../components/sections/NavigationBar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
import SolutionSection from '../components/sections/SolutionSection.astro';
import BenefitsSection from '../components/sections/BenefitsSection.astro';
import ServiceSection from '../components/sections/ServiceSection.astro';
import HeatmapComparisonSection from '../components/sections/HeatmapComparisonSection.astro';
import CompetitiveAdvantagesSection from '../components/sections/CompetitiveAdvantagesSection.astro';
import PlansSection from '../components/sections/PlansSection.astro';
import CoverageSection from '../components/sections/CoverageSection.astro';
import BuyerPersonaSection from '../components/sections/BuyerPersonaSection.astro';
import PilotDemoSection from '../components/sections/PilotDemoSection.astro';
import SustainabilitySection from '../components/sections/SustainabilitySection.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import TeamSection from '../components/sections/TeamSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import FinalCtaSection from '../components/sections/FinalCtaSection.astro';
import FooterSection from '../components/sections/FooterSection.astro';
import FloatingWhatsAppButton from '../components/sections/FloatingWhatsAppButton.astro';
import SuccessModal from '../components/sections/SuccessModal.astro';
import PageScripts from '../components/sections/PageScripts.astro';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ViñaGuard Tarija - Monitoreo Inteligente de Viñedos con Drones e IA</title>
  
  <!-- Tailwind CSS v4 -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  
  <!-- Google Fonts: Inter & Playfair Display for elegant wine branding -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icons for modern agriculture & technology UI -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  <style is:global>
    /* Custom font styling integration */
    body {
      font-family: 'Inter', sans-serif;
    }
    .font-serif {
      font-family: 'Playfair Display', Georgia, serif;
    }

    /* Elegant Custom Colors & Gradients */
    :root {
      --color-vine-green-50: #f4faf6;
      --color-vine-green-100: #e3f2e9;
      --color-vine-green-600: #1b5336;
      --color-vine-green-700: #143f29;
      --color-vine-green-900: #0a2015;
      --color-grape-wine-100: #f3e8ff;
      --color-grape-wine-600: #6b21a8;
      --color-grape-wine-800: #4c1d95;
      --color-grape-wine-950: #2e1065;
    }

    /* Custom Parallax Effect */
    .parallax-bg {
      background-attachment: fixed;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
    
    @media (max-width: 1024px) {
      .parallax-bg {
        background-attachment: scroll; /* Smoother on mobile */
      }
    }

    /* Image Slider Styles (Before/After) */
    .comparison-slider-container {
      position: relative;
      overflow: hidden;
    }
    
    .comparison-slider-img-overlay {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 50%;
      overflow: hidden;
    }

    /* Pulse effects for heatmap alerts */
    @keyframes custom-pulse {
      0%, 100% { transform: scale(1); opacity: 0.9; }
      50% { transform: scale(1.08); opacity: 1; filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.8)); }
    }
    .heatmap-alert-pulse {
      animation: custom-pulse 2s infinite ease-in-out;
    }

    /* Floating drone animation */
    @keyframes float-drone {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-12px) rotate(1deg); }
    }
    .drone-float {
      animation: float-drone 4s ease-in-out infinite;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 10px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--color-vine-green-600);
      border-radius: 5px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--color-grape-wine-800);
    }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 leading-relaxed overflow-x-hidden">

  <TopNotificationBar />
  <NavigationBar />
  <HeroSection />
  <ProblemSection />
  <SolutionSection />
  <BenefitsSection />
  <ServiceSection />
  <HeatmapComparisonSection />
  <CompetitiveAdvantagesSection />
  <PlansSection />
  <CoverageSection />
  <BuyerPersonaSection />
  <PilotDemoSection />
  <SustainabilitySection />
  <TestimonialsSection />
  <TeamSection />
  <ContactSection />
  <FinalCtaSection />
  <FooterSection />
  <FloatingWhatsAppButton />
  <SuccessModal />
  <PageScripts />
</body>
</html>
