    function selectMapRegion(regionId) {
      const data = coverageRegions[regionId] || coverageRegions.general;
      const paths = document.querySelectorAll('.tarija-municipality');
      const labels = document.querySelectorAll('.tarija-label');

      paths.forEach(pathEl => {
        pathEl.setAttribute('fill', pathEl.dataset.defaultFill);
        pathEl.setAttribute('stroke', pathEl.dataset.defaultStroke);
        pathEl.style.fillOpacity = '0.9';
        pathEl.style.strokeWidth = '1.4';
        pathEl.style.filter = 'none';
      });

      labels.forEach(labelEl => {
        labelEl.setAttribute('fill', '#334155');
        labelEl.setAttribute('font-size', '8.5');
      });

      const selectedPath = document.querySelector(`.tarija-municipality[data-region="${regionId}"]`);
      if (selectedPath) {
        selectedPath.setAttribute('stroke', data.activeStroke || '#14532d');
        selectedPath.style.fillOpacity = '1';
        selectedPath.style.strokeWidth = '3';
        selectedPath.style.filter = 'drop-shadow(0 8px 12px rgba(15, 23, 42, 0.18))';
      }

      const selectedLabel = document.querySelector(`.tarija-label[data-region="${regionId}"]`);
      if (selectedLabel) {
        selectedLabel.setAttribute('fill', data.activeStroke || '#14532d');
        selectedLabel.setAttribute('font-size', '9.5');
      }

      document.getElementById('cobertura-active-name').innerText = data.name;
      document.getElementById('cobertura-active-desc').innerText = data.desc;
      document.getElementById('cobertura-active-time').innerText = data.time;
      document.getElementById('cobertura-active-area').innerText = data.area;
    }

    document.querySelectorAll('.tarija-municipality').forEach(pathEl => {
      pathEl.addEventListener('click', () => selectMapRegion(pathEl.dataset.region));
      pathEl.addEventListener('keydown', event => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          selectMapRegion(pathEl.dataset.region);
        }
      });
    });


    // FORCE PRE-SELECTED PLAN VALUE FROM PLAN CARD CLICKS
