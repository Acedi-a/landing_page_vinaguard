      const ha = parseInt(document.getElementById('hectareas-calc').value);
      document.getElementById('hectareas-val').innerText = `${ha} Ha`;

      // Cost calculation: 100 Bs per hectare (reference minimum)
      const flightCost = ha * 100;
      
      // Formatting to currency
      const formattedCost = new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB', minimumFractionDigits: 0 }).format(flightCost);
      document.getElementById('estimado-vuelo').innerText = formattedCost.replace('BOB', '') + ' Bs';
    }
