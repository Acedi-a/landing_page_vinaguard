    function selectAISim(type) {
      // Toggle button classes
      const buttons = document.querySelectorAll('.ai-sim-btn');
      buttons.forEach(btn => {
        btn.classList.remove('border-emerald-500/30', 'bg-emerald-950/30', 'active');
        btn.classList.add('border-slate-800', 'bg-slate-900/50');
      });

      const activeBtn = document.getElementById(`btn-${type}`);
      activeBtn.classList.add('border-emerald-500/30', 'bg-emerald-950/30', 'active');
      activeBtn.classList.remove('border-slate-800', 'bg-slate-900/50');

      // Update simulation graphics
      const data = aiSimData[type];
      const imgEl = document.getElementById('sim-image');
      const boxEl = document.getElementById('sim-scanner-box');
      const labelEl = document.getElementById('sim-box-label');
      const statusEl = document.getElementById('sim-box-status');
      const recIconEl = document.getElementById('sim-rec-icon');
      const recTitleEl = document.getElementById('sim-rec-title');
      const recDescEl = document.getElementById('sim-rec-desc');

      // Smooth fade-out before changing src
      imgEl.style.opacity = 0.3;
      setTimeout(() => {
        imgEl.src = data.img;
        imgEl.style.opacity = 0.8;
      }, 150);

      // Adjust scanner bounding box
      boxEl.style.cssText = data.scannerStyle;
      labelEl.innerText = data.label;
      statusEl.innerText = data.status;

      // Adjust Recommendation text
      recTitleEl.innerText = data.recTitle;
      recDescEl.innerText = data.recDesc;

      // Adjust Icon inside alert
      recIconEl.className = `p-2 rounded-lg ${data.recIconColor}`;
      recIconEl.innerHTML = `<i class="fas ${data.recIcon}"></i>`;
    }


    // INTERACTIVE ESTIMATOR CALCULATOR
