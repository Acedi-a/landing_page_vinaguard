    // CONTACT FORM CLIENT-SIDE SUBMISSION & MODAL CONFIRMATION
    function handleFormSubmit(event) {
      event.preventDefault();

      // Collect data to display in custom success modal
      const name = document.getElementById('form-name').value;
      const bodega = document.getElementById('form-bodega').value;
      const ubicacion = document.getElementById('form-ubicacion').value;
      const hectareas = document.getElementById('form-hectareas').value;
      const telefono = document.getElementById('form-telefono').value;

      document.getElementById('modal-user-name').innerText = name;
      document.getElementById('modal-user-winery').innerText = bodega;
      document.getElementById('modal-user-location').innerText = ubicacion;
      document.getElementById('modal-user-ha').innerText = hectareas;
      document.getElementById('modal-user-phone').innerText = telefono;

      // Show modal with animation
      const modal = document.getElementById('success-modal');
      modal.classList.remove('hidden');
      modal.firstElementChild.classList.remove('scale-95', 'opacity-0');
      modal.firstElementChild.classList.add('scale-100', 'opacity-100');

      // Reset form
      document.getElementById('contact-form').reset();
    }

    function closeModal() {
      const modal = document.getElementById('success-modal');
      modal.firstElementChild.classList.remove('scale-100', 'opacity-100');
      modal.firstElementChild.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 200);
