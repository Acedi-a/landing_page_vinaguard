---
import tarijaMap from '../data/tarijaMunicipios.json';

const tarijaMunicipalities = tarijaMap.municipalities;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ViñaGuard Tarija - Monitoreo Inteligente de Viñedos con Drones e IA</title>
  
  <!-- Tailwind CSS v4 -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  
  <!-- Google Fonts: Inter & Playfair Display for elegant wine branding -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icons for modern agriculture & technology UI -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  <style>
    /* Custom font styling integration */
    body {
      font-family: 'Inter', sans-serif;
    }
    .font-serif {
      font-family: 'Playfair Display', Georgia, serif;
    }

    /* Elegant Custom Colors & Gradients */
    :root {
      --color-vine-green-50: #f4faf6;
      --color-vine-green-100: #e3f2e9;
      --color-vine-green-600: #1b5336;
      --color-vine-green-700: #143f29;
      --color-vine-green-900: #0a2015;
      --color-grape-wine-100: #f3e8ff;
      --color-grape-wine-600: #6b21a8;
      --color-grape-wine-800: #4c1d95;
      --color-grape-wine-950: #2e1065;
    }

    /* Custom Parallax Effect */
    .parallax-bg {
      background-attachment: fixed;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
    
    @media (max-width: 1024px) {
      .parallax-bg {
        background-attachment: scroll; /* Smoother on mobile */
      }
    }

    /* Image Slider Styles (Before/After) */
    .comparison-slider-container {
      position: relative;
      overflow: hidden;
    }
    
    .comparison-slider-img-overlay {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 50%;
      overflow: hidden;
    }

    /* Pulse effects for heatmap alerts */
    @keyframes custom-pulse {
      0%, 100% { transform: scale(1); opacity: 0.9; }
      50% { transform: scale(1.08); opacity: 1; filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.8)); }
    }
    .heatmap-alert-pulse {
      animation: custom-pulse 2s infinite ease-in-out;
    }

    /* Floating drone animation */
    @keyframes float-drone {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-12px) rotate(1deg); }
    }
    .drone-float {
      animation: float-drone 4s ease-in-out infinite;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 10px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--color-vine-green-600);
      border-radius: 5px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--color-grape-wine-800);
    }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 leading-relaxed overflow-x-hidden">

  <!-- ================= TOP NOTIFICATION BAR ================= -->
  <div class="bg-[var(--color-grape-wine-950)] text-white text-xs md:text-sm py-2 px-4 text-center font-medium border-b border-purple-900/50 flex justify-center items-center gap-2">
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500 text-purple-950 uppercase tracking-widest animate-pulse">Piloto 2026</span>
    <span>¡Pruebas piloto gratuitas para bodegas en el Valle Central de Tarija! Cupos limitados.</span>
    <a href="#contacto" class="underline hover:text-amber-300 font-bold ml-1 transition duration-150">Agendar Ahora &rarr;</a>
  </div>

  <!-- ================= NAVIGATION BAR ================= -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-3 group">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-600 to-purple-800 flex items-center justify-center text-white font-extrabold shadow-md shadow-emerald-900/20 group-hover:scale-105 transition-all duration-300">
            <span class="text-xl font-serif">V</span><span class="text-sm font-sans">G</span>
          </div>
          <div>
            <span class="text-xl font-bold tracking-tight text-gray-900 flex items-center gap-1.5 font-serif">
              Viña<span class="text-emerald-700 font-sans font-extrabold">Guard</span>
            </span>
            <span class="text-[10px] text-gray-500 block uppercase tracking-widest font-semibold font-sans">Tarija · Bolivia</span>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="#problema" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Problema</a>
          <a href="#solucion" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">La Solución</a>
          <a href="#beneficios" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Beneficios</a>
          <a href="#demostracion" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Mapa de Calor</a>
          <a href="#planes" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Planes</a>
          <a href="#cobertura" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Cobertura</a>
          <a href="#equipo" class="text-sm font-semibold text-gray-600 hover:text-emerald-700 transition duration-150">Equipo</a>
        </nav>

        <!-- CTA Buttons (Desktop) -->
        <div class="hidden lg:flex items-center gap-4">
          <a href="https://wa.me/59170000000?text=Hola%20ViñaGuard,%20me%20gustaría%20solicitar%20una%20demostración%20para%20mi%20viñedo." target="_blank" class="text-sm font-bold text-emerald-700 hover:text-emerald-800 transition duration-150 flex items-center gap-2">
            <i class="fab fa-whatsapp text-lg"></i> WhatsApp
          </a>
          <a href="#contacto" class="px-5 py-2.5 bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white text-sm font-bold rounded-lg shadow-md hover:shadow-lg transition-all duration-300">
            Solicitar Demo <i class="fas fa-arrow-right ml-1"></i>
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
          <button id="mobile-menu-btn" class="text-gray-700 p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-600" aria-label="Abrir Menú">
            <i class="fas fa-bars text-2xl"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Panel -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 pt-2 pb-6 space-y-3 shadow-inner">
      <a href="#problema" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">El Problema</a>
      <a href="#solucion" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">La Solución</a>
      <a href="#beneficios" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">Beneficios</a>
      <a href="#demostracion" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">Mapa de Calor</a>
      <a href="#planes" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">Planes de Servicio</a>
      <a href="#cobertura" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">Zonas de Cobertura</a>
      <a href="#equipo" class="block py-2 px-3 rounded-lg hover:bg-gray-50 text-base font-semibold text-gray-700">Nuestro Equipo</a>
      <div class="pt-4 border-t border-gray-100 flex flex-col gap-3">
        <a href="https://wa.me/59170000000?text=Hola%20ViñaGuard,%20me%20gustaría%20solicitar%20una%20demostración%20para%20mi%20viñedo." target="_blank" class="w-full text-center py-3 border border-emerald-600 text-emerald-700 rounded-lg font-bold flex items-center justify-center gap-2">
          <i class="fab fa-whatsapp text-xl"></i> Hablar por WhatsApp
        </a>
        <a href="#contacto" class="w-full text-center py-3 bg-emerald-600 text-white rounded-lg font-bold shadow-md">
          Solicitar Demostración
        </a>
      </div>
    </div>
  </header>

  <!-- ================= HERO SECTION (PARALLAX FLOW) ================= -->
  <section class="relative min-h-[90vh] flex items-center justify-center py-16 md:py-24 bg-cover bg-center parallax-bg overflow-hidden" style="background-image: linear-gradient(to bottom, rgba(15, 32, 21, 0.88), rgba(46, 16, 101, 0.92)), url('https://images.unsplash.com/photo-1506318137071-a8e063b4bec0?auto=format&fit=crop&w=2000&q=80');">
    <!-- Abstract Tech Mesh Background Elements -->
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <!-- Soft glowing ambient spots -->
    <div class="absolute top-1/4 left-10 w-96 h-96 bg-emerald-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-10 w-96 h-96 bg-purple-600/20 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Column: Copy & CTAs -->
        <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
          <!-- Tag -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/20 text-emerald-300 text-xs font-bold uppercase tracking-wider border border-emerald-400/30">
            <i class="fas fa-microchip"></i> Inteligencia Artificial Vitícola
          </div>

          <!-- Main Title -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight font-serif">
            Protege tu viñedo antes de que la <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 to-amber-300 font-sans italic font-normal">enfermedad avance</span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg sm:text-xl text-emerald-100/90 font-medium max-w-2xl mx-auto lg:mx-0">
            Monitoreo con drones e inteligencia artificial para detectar enfermedades, generar mapas de calor y tomar mejores decisiones en tu viñedo del Valle de Tarija.
          </p>

          <!-- Short Text -->
          <p class="text-sm sm:text-base text-gray-300 max-w-xl mx-auto lg:mx-0">
            ViñaGuard ayuda a bodegas y productores de Tarija a identificar focos de riesgo en sus cultivos, reducir pérdidas de cosecha y optimizar el uso de agroquímicos mediante reportes claros y fáciles de entender.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
            <a href="#contacto" class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white font-bold rounded-xl shadow-lg shadow-emerald-950/40 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 text-center">
              Solicitar demostración <i class="fas fa-calendar-alt ml-2"></i>
            </a>
            <a href="https://wa.me/59170000000?text=Hola%20ViñaGuard,%20me%20gustaría%20solicitar%20una%20demostración%20para%20mi%20viñedo." target="_blank" class="w-full sm:w-auto px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold rounded-xl hover:-translate-y-0.5 transition-all duration-200 text-center flex items-center justify-center gap-2">
              <i class="fab fa-whatsapp text-emerald-400 text-xl"></i> Hablar por WhatsApp
            </a>
          </div>

          <!-- Features Badges / Indicators -->
          <div class="pt-8 border-t border-white/10 grid grid-cols-2 sm:grid-cols-4 gap-4 text-left max-w-2xl mx-auto lg:mx-0">
            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 shrink-0 mt-0.5">
                <i class="fas fa-search-plus text-xs"></i>
              </div>
              <div>
                <h4 class="text-xs font-bold text-white uppercase tracking-wider">Detección temprana</h4>
                <p class="text-[11px] text-gray-400">Mildiu, Oídio, Botrytis</p>
              </div>
            </div>

            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-purple-500/10 border border-purple-500/30 flex items-center justify-center text-purple-400 shrink-0 mt-0.5">
                <i class="fas fa-fire text-xs"></i>
              </div>
              <div>
                <h4 class="text-xs font-bold text-white uppercase tracking-wider">Mapas de calor</h4>
                <p class="text-[11px] text-gray-400">Zonas de estrés y focos</p>
              </div>
            </div>

            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 shrink-0 mt-0.5">
                <i class="fab fa-whatsapp text-xs"></i>
              </div>
              <div>
                <h4 class="text-xs font-bold text-white uppercase tracking-wider">Reportes por WA</h4>
                <p class="text-[11px] text-gray-400">Alertas directas al celular</p>
              </div>
            </div>

            <div class="flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-400 shrink-0 mt-0.5">
                <i class="fas fa-bullseye text-xs"></i>
              </div>
              <div>
                <h4 class="text-xs font-bold text-white uppercase tracking-wider">Recomendación</h4>
                <p class="text-[11px] text-gray-400">Tratamiento preciso</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Interactive Graphic / Phone & Drone Mockup -->
        <div class="lg:col-span-5 flex justify-center relative">
          <!-- Back circle glow -->
          <div class="absolute w-72 h-72 bg-gradient-to-tr from-emerald-600/30 to-purple-800/30 rounded-full blur-2xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
          
          <div class="relative w-full max-w-[420px] mx-auto">
            <!-- Drone Floating Asset -->
            <div class="absolute -top-12 -right-8 w-44 h-44 drone-float z-20 pointer-events-none drop-shadow-[0_15px_15px_rgba(0,0,0,0.4)]">
              <img src="https://images.unsplash.com/photo-1527977966376-1c8408f9f108?auto=format&fit=crop&w=300&q=80" alt="Drone ViñaGuard" class="w-full h-full object-cover rounded-full border-4 border-white shadow-2xl" />
              <div class="absolute bottom-1 left-1 bg-emerald-600 text-white text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider shadow">Dron RGB</div>
            </div>

            <!-- Main App/Dashboard Mockup in a simulated iPad/Tablet -->
            <div class="w-full bg-slate-900 rounded-3xl p-3 border-4 border-slate-700 shadow-2xl relative overflow-hidden">
              <div class="absolute top-1.5 left-1/2 -translate-x-1/2 w-20 h-4 bg-slate-700 rounded-full"></div>
              
              <div class="bg-slate-950 rounded-2xl p-4 pt-6 text-white space-y-4">
                <!-- App Header -->
                <div class="flex items-center justify-between border-b border-slate-800 pb-3">
                  <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-xs font-bold tracking-wider text-gray-300">ViñaGuard AI v1.4</span>
                  </div>
                  <span class="text-[10px] bg-emerald-950 text-emerald-400 px-2 py-0.5 rounded font-mono font-bold">VALLE CENTRAL</span>
                </div>

                <!-- Live Heatmap Frame -->
                <div class="relative h-48 rounded-xl overflow-hidden border border-slate-800">
                  <img src="https://images.unsplash.com/photo-1516594915697-87eb3b1c14ea?auto=format&fit=crop&w=600&q=80" alt="Vuelo Drone" class="w-full h-full object-cover opacity-60" />
                  
                  <!-- Heatmap overlays -->
                  <div class="absolute inset-0 bg-gradient-to-tr from-red-500/40 via-yellow-400/25 to-emerald-500/20 pointer-events-none mix-blend-color-burn"></div>
                  
                  <!-- Simulated scanline -->
                  <div class="absolute inset-x-0 h-0.5 bg-emerald-400 shadow-[0_0_10px_#10b981] animate-[bounce_3s_infinite] top-1/3"></div>

                  <!-- Alert Marker 1 -->
                  <div class="absolute top-1/4 left-1/3 heatmap-alert-pulse">
                    <span class="flex h-3 w-3 relative">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-red-600"></span>
                    </span>
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 bg-slate-900/95 border border-red-500/50 rounded-lg p-1.5 text-[9px] whitespace-nowrap shadow-lg">
                      <span class="font-bold text-red-400">Foco #12: MILDIU</span><br/>
                      <span>Prob: 94% · Foco crítico</span>
                    </div>
                  </div>

                  <!-- Alert Marker 2 -->
                  <div class="absolute bottom-1/4 right-1/4">
                    <span class="flex h-3 w-3 relative">
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
                    </span>
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 bg-slate-900/95 border border-amber-500/50 rounded-lg p-1.5 text-[9px] whitespace-nowrap shadow-lg">
                      <span class="font-bold text-amber-400">Foco #14: ESTRÉS</span><br/>
                      <span>Prob: 78% · Moderado</span>
                    </div>
                  </div>
                </div>

                <!-- Live Metrics -->
                <div class="grid grid-cols-3 gap-2">
                  <div class="bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-center">
                    <p class="text-[9px] text-gray-400 uppercase font-semibold">Salud General</p>
                    <p class="text-base font-extrabold text-emerald-400">88.4%</p>
                  </div>
                  <div class="bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-center">
                    <p class="text-[9px] text-gray-400 uppercase font-semibold">Área Escaneada</p>
                    <p class="text-base font-extrabold text-white">42 Ha</p>
                  </div>
                  <div class="bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-center">
                    <p class="text-[9px] text-gray-400 uppercase font-semibold">Riesgos Activos</p>
                    <p class="text-base font-extrabold text-red-400">2 focos</p>
                  </div>
                </div>

                <!-- Recommendation box -->
                <div class="bg-emerald-950/40 border border-emerald-500/30 rounded-xl p-3 flex gap-2.5 items-start">
                  <div class="text-emerald-400 p-1.5 bg-emerald-500/10 rounded-lg shrink-0">
                    <i class="fas fa-file-invoice text-sm"></i>
                  </div>
                  <div class="text-[11px]">
                    <span class="font-bold text-emerald-300">Recomendación de Tratamiento</span>
                    <p class="text-gray-300 mt-0.5">Aplicación localizada de fungicida orgánico en Cuadro 4B (Uriondo) evita expansión y reduce uso de químicos en 75%.</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- WhatsApp Notification Card Float -->
            <div class="absolute -bottom-6 -left-8 bg-white text-gray-800 p-3.5 rounded-xl shadow-xl max-w-[240px] border border-gray-100 flex items-start gap-3 z-20">
              <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 shrink-0">
                <i class="fab fa-whatsapp text-lg"></i>
              </div>
              <div class="text-xs">
                <div class="flex items-center justify-between">
                  <span class="font-bold text-gray-900">ViñaGuard Alertas</span>
                  <span class="text-[9px] text-gray-400">Ahora</span>
                </div>
                <p class="text-gray-600 text-[11px] mt-0.5">⚠️ <span class="font-semibold text-purple-950">Mildiu detectado</span> en sector Norte de Viñedos Méndez. Ver mapa: bit.ly/v-1234</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================= EL PROBLEMA ================= -->
  <section id="problema" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
        <span class="text-emerald-700 font-bold text-xs uppercase tracking-widest block"><i class="fas fa-exclamation-circle mr-1"></i> Desafíos en el Campo</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-serif">
          Monitorear el viñedo a simple vista ya no es suficiente
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-emerald-600 to-purple-600 mx-auto rounded-full"></div>
        <p class="text-gray-600 text-base sm:text-lg">
          En muchos viñedos de Tarija, el monitoreo todavía se realiza caminando entre las plantas. Este método puede ser lento, impreciso y difícil en terrenos con laderas o parcelas fragmentadas. Cuando la enfermedad se detecta tarde, la pérdida de producción y el gasto en agroquímicos pueden aumentar considerablemente.
        </p>
      </div>

      <!-- Problem Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        
