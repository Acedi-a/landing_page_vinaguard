    // INTERACTIVE BEFORE-AFTER COMPARISON SLIDER (TOUCH & MOUSE ENABLED)
    const compareSlider = document.getElementById('vine-compare-slider');
    const compareHandle = document.getElementById('compare-handle');
    const compareOverlayWrapper = document.getElementById('compare-overlay-wrapper');
    const compareOverlayImg = document.getElementById('compare-overlay-img');

    // Handle responsiveness on window resize so coordinates align
    function adjustCompareImgWidth() {
      const sliderWidth = compareSlider.offsetWidth;
      compareOverlayImg.style.width = sliderWidth + 'px';
    }
    
    window.addEventListener('resize', adjustCompareImgWidth);
    adjustCompareImgWidth();

    // Slider Dragging Mechanics
    let isDragging = false;

    function handleSliderMove(clientX) {
      const rect = compareSlider.getBoundingClientRect();
      const positionX = clientX - rect.left;
      let percentage = (positionX / rect.width) * 100;
      
      // Restrict percentage between boundaries
      if (percentage < 0) percentage = 0;
      if (percentage > 100) percentage = 100;
      
      // Apply width and left positions
      compareHandle.style.left = percentage + '%';
      compareOverlayWrapper.style.width = percentage + '%';
    }

    // Mouse events
    compareSlider.addEventListener('mousedown', (e) => {
      isDragging = true;
      handleSliderMove(e.clientX);
    });

    window.addEventListener('mouseup', () => {
      isDragging = false;
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      handleSliderMove(e.clientX);
    });

    // Touch events for mobile phones/tablets
    compareSlider.addEventListener('touchstart', (e) => {
      isDragging = true;
      handleSliderMove(e.touches[0].clientX);
    });

    window.addEventListener('touchend', () => {
      isDragging = false;
    });

    window.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      handleSliderMove(e.touches[0].clientX);
    });


    // INTERACTIVE AI DETECTION SIMULATOR DATA
