<!-- ================= LA SOLUCIÓN ================= -->
  <section id="solucion" class="py-20 bg-gradient-to-b from-gray-50 to-[var(--color-vine-green-50)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
        <span class="text-emerald-700 font-bold text-xs uppercase tracking-widest block"><i class="fas fa-check-circle mr-1"></i> Nuestra Propuesta</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-serif">
          ViñaGuard convierte imágenes aéreas en decisiones inteligentes
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-emerald-600 to-purple-600 mx-auto rounded-full"></div>
        <p class="text-gray-600 text-base sm:text-lg">
          Con vuelos programados de drones y análisis con inteligencia artificial, ViñaGuard identifica zonas críticas del viñedo y entrega información útil para actuar a tiempo.
        </p>
      </div>

      <!-- Steps Timeline Process -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        <!-- Connecting Line for desktop -->
        <div class="hidden lg:block absolute top-1/2 left-4 right-4 h-0.5 bg-gradient-to-r from-emerald-200 via-purple-200 to-emerald-200 -translate-y-16 -z-10"></div>

        <!-- Step 1 -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 relative group">
          <div class="absolute -top-5 left-8 w-10 h-10 rounded-full bg-emerald-600 text-white font-extrabold flex items-center justify-center text-sm shadow-md">
            1
          </div>
          <div class="w-14 h-14 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center text-2xl mb-6 group-hover:scale-105 transition duration-300">
            <i class="fab fa-whatsapp"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Agendamos el vuelo</h3>
          <p class="text-xs text-gray-600">
            El productor solicita el monitoreo por WhatsApp o mediante nuestra plataforma. Coordinamos el día óptimo para volar de acuerdo al clima local de Tarija.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 relative group">
          <div class="absolute -top-5 left-8 w-10 h-10 rounded-full bg-purple-600 text-white font-extrabold flex items-center justify-center text-sm shadow-md">
            2
          </div>
          <div class="w-14 h-14 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center text-2xl mb-6 group-hover:scale-105 transition duration-300">
            <i class="fas fa-helicopter"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Volamos sobre el viñedo</h3>
          <p class="text-xs text-gray-600">
            Nuestros pilotos certificados despliegan drones equipados con cámaras RGB de alta resolución para capturar miles de imágenes detalladas del follaje en pocas horas.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 relative group">
          <div class="absolute -top-5 left-8 w-10 h-10 rounded-full bg-emerald-600 text-white font-extrabold flex items-center justify-center text-sm shadow-md">
            3
          </div>
          <div class="w-14 h-14 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center text-2xl mb-6 group-hover:scale-105 transition duration-300">
            <i class="fas fa-brain"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">La IA analiza las imágenes</h3>
          <p class="text-xs text-gray-600">
            Nuestras redes neuronales convolucionales (CNN) examinan los patrones de color y textura de cada planta, localizando indicios de mildiu, oídio, botrytis y estrés.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 relative group">
          <div class="absolute -top-5 left-8 w-10 h-10 rounded-full bg-purple-600 text-white font-extrabold flex items-center justify-center text-sm shadow-md">
            4
          </div>
          <div class="w-14 h-14 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center text-2xl mb-6 group-hover:scale-105 transition duration-300">
            <i class="fas fa-file-pdf"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Entregamos el informe</h3>
          <p class="text-xs text-gray-600">
            Enviamos mapas de calor georreferenciados, recomendaciones claras de agrónomos y evidencias en formato PDF interactivo y WhatsApp para actuar con precisión.
          </p>
        </div>

      </div>

      <!-- INTERACTIVE AI DETECTION SIMULATOR -->
      <div class="mt-16 bg-slate-900 rounded-3xl border border-slate-800 shadow-2xl p-6 md:p-10 text-white">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
          
          <div class="lg:col-span-5 space-y-6">
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-purple-500/20 text-purple-300 text-xs font-bold border border-purple-500/30">
              <span class="w-1.5 h-1.5 rounded-full bg-purple-400 animate-ping"></span> Simulación Interactiva
            </div>
            <h3 class="text-2xl sm:text-3xl font-extrabold font-serif">Cómo detecta la IA en tiempo real</h3>
            <p class="text-sm text-gray-300 leading-relaxed">
              Presiona los diferentes botones para ver cómo nuestro modelo de Inteligencia Artificial (CNN) escanea e identifica las firmas visuales de cada patología foliar.
            </p>

            <!-- Buttons Selector -->
            <div class="flex flex-col gap-3" id="ai-simulator-buttons">
              <button onclick="selectAISim('mildiu')" id="btn-mildiu" class="ai-sim-btn w-full text-left px-4 py-3 rounded-xl border border-emerald-500/30 bg-emerald-950/30 hover:bg-emerald-950/50 transition-all duration-200 flex items-center justify-between group active">
                <span class="flex items-center gap-3">
                  <span class="w-3 h-3 rounded-full bg-red-500"></span>
                  <span class="text-xs font-bold uppercase tracking-wider">Mildiu detectado (Plaga)</span>
                </span>
                <i class="fas fa-chevron-right text-gray-500 group-hover:translate-x-1 transition"></i>
              </button>

              <button onclick="selectAISim('oidio')" id="btn-oidio" class="ai-sim-btn w-full text-left px-4 py-3 rounded-xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800/40 transition-all duration-200 flex items-center justify-between group">
                <span class="flex items-center gap-3">
                  <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                  <span class="text-xs font-bold uppercase tracking-wider">Oídio (Hongo foliar)</span>
                </span>
                <i class="fas fa-chevron-right text-gray-500 group-hover:translate-x-1 transition"></i>
              </button>

              <button onclick="selectAISim('botrytis')" id="btn-botrytis" class="ai-sim-btn w-full text-left px-4 py-3 rounded-xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800/40 transition-all duration-200 flex items-center justify-between group">
                <span class="flex items-center gap-3">
                  <span class="w-3 h-3 rounded-full bg-orange-500"></span>
                  <span class="text-xs font-bold uppercase tracking-wider">Botrytis (Podredumbre)</span>
                </span>
                <i class="fas fa-chevron-right text-gray-500 group-hover:translate-x-1 transition"></i>
              </button>

              <button onclick="selectAISim('estres')" id="btn-estres" class="ai-sim-btn w-full text-left px-4 py-3 rounded-xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800/40 transition-all duration-200 flex items-center justify-between group">
                <span class="flex items-center gap-3">
                  <span class="w-3 h-3 rounded-full bg-blue-500"></span>
                  <span class="text-xs font-bold uppercase tracking-wider">Estrés Hídrico</span>
                </span>
                <i class="fas fa-chevron-right text-gray-500 group-hover:translate-x-1 transition"></i>
              </button>
            </div>
          </div>

          <!-- Simulation Frame -->
          <div class="lg:col-span-7 bg-slate-950 rounded-2xl p-4 border border-slate-800 shadow-inner relative min-h-[350px] flex flex-col justify-between">
            <!-- Simulated AI Screen Header -->
            <div class="flex items-center justify-between border-b border-slate-900 pb-3 mb-4">
              <span class="text-[10px] tracking-wider text-slate-500 uppercase font-mono font-bold">Consola de Análisis ViñaGuard AI v1.4</span>
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <span class="text-[9px] text-emerald-400 font-mono">Conectado</span>
              </div>
            </div>

            <!-- Dynamic Image & Scanning overlays -->
            <div class="relative flex-1 rounded-xl overflow-hidden min-h-[220px]">
              <!-- Base Vineyard Images dynamically changed -->
              <img id="sim-image" src="https://images.unsplash.com/photo-1516594915697-87eb3b1c14ea?auto=format&fit=crop&w=800&q=80" alt="Vineyard Sim" class="absolute inset-0 w-full h-full object-cover opacity-80" />
              
              <!-- Hotspot scanner visual effect -->
              <div id="sim-scanner-box" class="absolute border-2 border-red-500 bg-red-500/20 rounded-xl flex flex-col justify-between p-2 shadow-[0_0_15px_rgba(239,68,68,0.5)] transition-all duration-500" style="top: 20%; left: 15%; width: 150px; height: 120px;">
                <span class="text-[9px] font-mono font-bold bg-red-600 text-white px-1.5 py-0.5 rounded w-max">RE CONOCIMIENTO</span>
                <div class="text-[9px] font-mono text-white bg-slate-900/90 p-1 rounded border border-red-500/30">
                  <span id="sim-box-label">Mildiu: 94.2%</span><br/>
                  <span id="sim-box-status">Sector Crítico (Cuadro 4)</span>
                </div>
              </div>

              <!-- General Scan Overlay -->
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent via-slate-950/20 to-slate-950/80 pointer-events-none"></div>
            </div>

            <!-- Recommendation Alert Text -->
            <div class="mt-4 p-3 bg-slate-900 rounded-xl border border-slate-800 flex gap-3 items-center">
              <div class="p-2 rounded-lg bg-red-500/10 text-red-400" id="sim-rec-icon">
                <i class="fas fa-exclamation-triangle"></i>
              </div>
              <div>
                <h4 class="text-xs font-bold text-white uppercase tracking-wider" id="sim-rec-title">Alerta Crítica: Infección Activa de Mildiu</h4>
                <p class="text-[11px] text-gray-400 mt-0.5" id="sim-rec-desc">Infección avanzada detectada en el sector noroeste. Se recomienda aplicar fungicida a base de cobre con dosis dirigida en un radio de 15 metros.</p>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
