---
import tarijaMap from '../data/tarijaMunicipios.json';

const activeMunicipalities = new Set(['tarija', 'uriondo', 'yunchara']);
---

<div class="tarija-map-3d" data-tarija-map-3d>
  <div class="tarija-map-3d__toolbar">
    <span class="tarija-map-3d__pin"><i class="fas fa-location-dot"></i></span>
    <span>
      <strong>Toca un municipio</strong>
      <small>para consultar disponibilidad logística</small>
    </span>
  </div>

  <canvas class="tarija-map-3d__canvas" data-tarija-map-canvas aria-label="Mapa 3D municipal del departamento de Tarija"></canvas>

  <div class="tarija-map-3d__labels" data-tarija-map-labels>
    {tarijaMap.municipalities.map((municipio) => (
      <button
        type="button"
        class:list={[
          'tarija-map-3d__label',
          activeMunicipalities.has(municipio.slug) && 'tarija-map-3d__label--active',
        ]}
        data-map-label={municipio.slug}
        aria-label={`${municipio.name}, provincia ${municipio.province}`}
      >
        {municipio.name}
      </button>
    ))}
  </div>

  <div class="tarija-map-3d__legend" aria-label="Leyenda de disponibilidad">
    <span><i class="tarija-map-3d__dot tarija-map-3d__dot--immediate"></i> Inmediata</span>
    <span><i class="tarija-map-3d__dot tarija-map-3d__dot--soon"></i> &lt; 24 h</span>
    <span><i class="tarija-map-3d__dot tarija-map-3d__dot--planned"></i> Expansión</span>
  </div>

  <script type="application/json" data-tarija-map-payload set:html={JSON.stringify(tarijaMap)}></script>
</div>

  <script>
  import * as THREE from 'three';
  import { SVGLoader } from 'three/examples/jsm/loaders/SVGLoader.js';

  const roots = document.querySelectorAll('[data-tarija-map-3d]');
  const SELECTED_REGION_EVENT = 'tarija-map:select-region';
  const PANEL_REGION_EVENT = 'tarija:select';

  const colorByStatus = {
    'cobertura-inmediata': {
      top: '#8b5cf6',
      side: '#6d28d9',
      stroke: '#ffffff',
      selectedTop: '#7c3aed',
      selectedSide: '#4c1d95',
    },
    'respuesta-24h': {
      top: '#f5c84b',
      side: '#d99a00',
      stroke: '#ffffff',
      selectedTop: '#f59e0b',
      selectedSide: '#b45309',
    },
    expansion: {
      top: '#eef5ee',
      side: '#c8d8ce',
      stroke: '#ffffff',
      selectedTop: '#10b981',
      selectedSide: '#047857',
    },
  };

  const selectedOverrides = {
    uriondo: {
      top: '#21c28a',
      side: '#0f8f67',
      selectedTop: '#10b981',
      selectedSide: '#047857',
    },
    tarija: {
      top: '#9b5cf6',
      side: '#6d28d9',
      selectedTop: '#7c3aed',
      selectedSide: '#4c1d95',
    },
  };

  const shade = (hex, amount) => {
    const color = new THREE.Color(hex);
    color.offsetHSL(0, 0, amount);
    return `#${color.getHexString()}`;
  };

  roots.forEach((root) => {
    const payloadEl = root.querySelector('[data-tarija-map-payload]');
    const canvas = root.querySelector('[data-tarija-map-canvas]');
    const labelLayer = root.querySelector('[data-tarija-map-labels]');
    const mapData = JSON.parse(payloadEl.textContent);
    const [viewWidth, viewHeight] = mapData.viewBox.split(' ').slice(2).map(Number);
    const depth = 17;
    const regionGroups = new Map();
    const pickables = [];
    const labelButtons = Array.from(root.querySelectorAll('[data-map-label]'));
    let selectedRegion = null;
    let hoveredRegion = null;
    let animationFrame = null;

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2('#e9f6f1', 0.0024);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0.1, 1200);
    camera.position.set(10, 250, 210);
    camera.lookAt(12, 0, -8);

    const mapGroup = new THREE.Group();
    mapGroup.rotation.z = -0.01;
    mapGroup.scale.z = -1;
    scene.add(mapGroup);

    const ambientLight = new THREE.HemisphereLight('#ffffff', '#9bc5ad', 2.6);
    scene.add(ambientLight);

    const mainLight = new THREE.DirectionalLight('#ffffff', 3.4);
    mainLight.position.set(-150, 300, 180);
    mainLight.castShadow = true;
    mainLight.shadow.mapSize.set(2048, 2048);
    mainLight.shadow.camera.left = -280;
    mainLight.shadow.camera.right = 280;
    mainLight.shadow.camera.top = 220;
    mainLight.shadow.camera.bottom = -220;
    mainLight.shadow.camera.near = 50;
    mainLight.shadow.camera.far = 700;
    scene.add(mainLight);

    const fillLight = new THREE.DirectionalLight('#d7fff0', 1.7);
    fillLight.position.set(180, 160, -210);
    scene.add(fillLight);

    const shadowPlane = new THREE.Mesh(
      new THREE.PlaneGeometry(560, 380),
      new THREE.ShadowMaterial({
        color: '#047857',
        opacity: 0.24,
        transparent: true,
      })
    );
    shadowPlane.rotation.x = -Math.PI / 2;
    shadowPlane.position.set(6, -8, -4);
    shadowPlane.receiveShadow = true;
    scene.add(shadowPlane);

    const loader = new SVGLoader();

    function getPalette(municipio) {
      const base = {
        ...colorByStatus[municipio.status || 'expansion'],
        ...(selectedOverrides[municipio.slug] || {}),
      };
      if (municipio.slug === 'uriondo') return base;
      if (municipio.slug === 'tarija') return base;
      if (municipio.status === 'expansion') {
        return {
          ...base,
          top: municipio.fill || base.top,
          side: shade(municipio.stroke || base.side, -0.08),
        };
      }
      return base;
    }

    function makeRegion(municipio) {
      const parsed = loader.parse(`<svg xmlns="http://www.w3.org/2000/svg"><path d="${municipio.path}" /></svg>`);
      const group = new THREE.Group();
      const palette = getPalette(municipio);
      group.userData = { municipio, palette };

      parsed.paths.forEach((path) => {
        SVGLoader.createShapes(path).forEach((shape) => {
          const geometry = new THREE.ExtrudeGeometry(shape, {
            depth,
            bevelEnabled: true,
            bevelSize: 1.6,
            bevelThickness: 1.8,
            bevelSegments: 3,
            curveSegments: 5,
          });
          geometry.rotateX(-Math.PI / 2);
          geometry.translate(-viewWidth / 2, 0, viewHeight / 2);

          const topMaterial = new THREE.MeshStandardMaterial({
            color: palette.top,
            roughness: municipio.status === 'expansion' ? 0.82 : 0.58,
            metalness: 0.02,
            emissive: '#000000',
            emissiveIntensity: 0,
          });
          const sideMaterial = new THREE.MeshStandardMaterial({
            color: palette.side,
            roughness: 0.84,
            metalness: 0.01,
          });
          const mesh = new THREE.Mesh(geometry, [topMaterial, sideMaterial]);
          mesh.castShadow = true;
          mesh.receiveShadow = true;
          mesh.userData.region = municipio.slug;
          mesh.userData.parentGroup = group;
          group.add(mesh);
          pickables.push(mesh);

          const outline = new THREE.LineSegments(
            new THREE.EdgesGeometry(geometry, 34),
            new THREE.LineBasicMaterial({
              color: palette.stroke,
              transparent: true,
              opacity: municipio.status === 'expansion' ? 0.8 : 0.96,
            })
          );
          outline.position.y = 0.2;
          outline.userData.region = municipio.slug;
          group.add(outline);
        });
      });

      group.position.y = municipio.status === 'expansion' ? 0 : 2.2;
      mapGroup.add(group);
      regionGroups.set(municipio.slug, group);
    }

    mapData.municipalities.forEach(makeRegion);

    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();

    function render() {
      animationFrame = null;
      renderer.render(scene, camera);
      updateLabels();
    }

    function scheduleRender() {
      if (!animationFrame) {
        animationFrame = requestAnimationFrame(render);
      }
    }

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, rect.width);
      const height = Math.max(1, rect.height);
      const aspect = width / height;
      const frustum = width < 520 ? 452 : 390;
      camera.left = (-frustum * aspect) / 2;
      camera.right = (frustum * aspect) / 2;
      camera.top = frustum / 2;
      camera.bottom = -frustum / 2;
      camera.updateProjectionMatrix();
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(width, height, false);
      scheduleRender();
    }

    function projectLabel(municipio) {
      const vector = new THREE.Vector3(
        municipio.labelX - viewWidth / 2,
        depth + 8,
        municipio.labelY - viewHeight / 2
      );
      vector.project(camera);
      return {
        x: (vector.x * 0.5 + 0.5) * root.clientWidth,
        y: (-vector.y * 0.5 + 0.5) * root.clientHeight,
      };
    }

    function updateLabels() {
      mapData.municipalities.forEach((municipio) => {
        const button = labelLayer.querySelector(`[data-map-label="${municipio.slug}"]`);
        if (!button) return;
        const position = projectLabel(municipio);
        button.style.left = `${position.x}px`;
        button.style.top = `${position.y}px`;
      });
    }

    function applyVisualState() {
      regionGroups.forEach((group, slug) => {
        const { municipio, palette } = group.userData;
        const isSelected = slug === selectedRegion;
        const isHovered = slug === hoveredRegion && !selectedRegion;
        group.position.y = isSelected ? 8 : municipio.status === 'expansion' ? 0 : 2.2;

        group.traverse((object) => {
          if (object.isMesh) {
            const topMaterial = object.material[0];
            const sideMaterial = object.material[1];
            topMaterial.color.set(isSelected || isHovered ? palette.selectedTop : palette.top);
            sideMaterial.color.set(isSelected || isHovered ? palette.selectedSide : palette.side);
            topMaterial.emissive.set(isSelected ? palette.selectedTop : '#000000');
            topMaterial.emissiveIntensity = isSelected ? 0.08 : 0;
          }
          if (object.isLineSegments) {
            object.material.opacity = isSelected ? 1 : municipio.status === 'expansion' ? 0.76 : 0.92;
            object.material.color.set(isSelected ? '#ffffff' : palette.stroke);
          }
        });
      });

      labelButtons.forEach((button) => {
        const isSelected = button.dataset.mapLabel === selectedRegion;
        button.classList.toggle('is-selected', isSelected);
      });

      scheduleRender();
    }

    function selectRegion(region, notify = true) {
      if (!regionGroups.has(region)) return;
      selectedRegion = region;
      applyVisualState();
      if (notify) {
        window.dispatchEvent(new CustomEvent(PANEL_REGION_EVENT, { detail: { region } }));
      }
    }

    function setPointer(event) {
      const rect = canvas.getBoundingClientRect();
      pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
    }

    function getIntersectedRegion(event) {
      setPointer(event);
      raycaster.setFromCamera(pointer, camera);
      const intersects = raycaster.intersectObjects(pickables, false);
      return intersects[0]?.object?.userData?.region || null;
    }

    canvas.addEventListener('pointermove', (event) => {
      const region = getIntersectedRegion(event);
      if (region === hoveredRegion) return;
      hoveredRegion = region;
      root.classList.toggle('is-hovering', Boolean(region));
      applyVisualState();
    });

    canvas.addEventListener('pointerleave', () => {
      hoveredRegion = null;
      root.classList.remove('is-hovering');
      applyVisualState();
    });

    canvas.addEventListener('click', (event) => {
      const region = getIntersectedRegion(event);
      if (region) selectRegion(region);
    });

    labelButtons.forEach((button) => {
      button.addEventListener('click', () => selectRegion(button.dataset.mapLabel));
    });

    window.addEventListener(SELECTED_REGION_EVENT, (event) => {
      selectRegion(event.detail.region, false);
    });

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();
    scheduleRender();
  });
</script>

<style>
  .tarija-map-3d {
    position: relative;
    min-height: clamp(430px, 50vw, 610px);
    overflow: visible;
    isolation: isolate;
    border: 0;
    background: transparent;
  }

  .tarija-map-3d::before {
    position: absolute;
    right: 2%;
    bottom: 10%;
    left: 5%;
    z-index: 0;
    height: 38%;
    content: "";
    pointer-events: none;
    background:
      radial-gradient(ellipse at center, rgba(4, 120, 87, 0.48) 0%, rgba(16, 185, 129, 0.25) 42%, rgba(16, 185, 129, 0) 74%);
    border-radius: 999px;
    filter: blur(24px);
    transform: rotate(-5deg);
  }

  .tarija-map-3d::after {
    position: absolute;
    inset: 12% -4% 4% 0;
    z-index: 0;
    content: "";
    pointer-events: none;
    background:
      repeating-radial-gradient(ellipse at 70% 70%, rgba(255, 255, 255, 0.58) 0 1px, transparent 1px 34px);
    opacity: 0.48;
  }

  .tarija-map-3d.is-hovering {
    cursor: pointer;
  }

  .tarija-map-3d__canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
  }

  .tarija-map-3d__toolbar {
    position: absolute;
    top: 16px;
    right: clamp(12px, 4vw, 44px);
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 12px;
    width: min(320px, calc(100% - 32px));
    padding: 10px 14px;
    color: #64748b;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 14px;
    box-shadow: 0 15px 36px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(12px);
  }

  .tarija-map-3d__toolbar strong {
    display: block;
    color: #047857;
    font-size: 11px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tarija-map-3d__toolbar small {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1.25;
  }

  .tarija-map-3d__pin {
    display: grid;
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    place-items: center;
    color: #047857;
    background: #dcfce7;
    border-radius: 12px;
    font-size: 18px;
  }

  .tarija-map-3d__labels {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .tarija-map-3d__label {
    position: absolute;
    max-width: 86px;
    padding: 3px 7px;
    color: #334155;
    font-size: 10px;
    font-weight: 900;
    line-height: 1.1;
    text-align: center;
    white-space: nowrap;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 8px;
    box-shadow: 0 5px 12px rgba(15, 23, 42, 0.12);
    transform: translate(-50%, -50%);
    transition:
      color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
    pointer-events: auto;
  }

  .tarija-map-3d__label--active {
    color: #047857;
    background: rgba(255, 255, 255, 0.9);
  }

  .tarija-map-3d__label.is-selected {
    color: #ffffff;
    background: #047857;
    box-shadow: 0 10px 22px rgba(4, 120, 87, 0.32);
    transform: translate(-50%, -50%) translateY(-4px);
  }

  .tarija-map-3d__legend {
    position: absolute;
    right: 16px;
    bottom: 16px;
    left: 16px;
    z-index: 4;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    width: fit-content;
    max-width: calc(100% - 32px);
    margin: 0 auto;
    padding: 12px 18px;
    color: #64748b;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 14px;
    box-shadow: 0 15px 34px rgba(15, 23, 42, 0.11);
    backdrop-filter: blur(12px);
  }

  .tarija-map-3d__legend span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .tarija-map-3d__dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.04);
  }

  .tarija-map-3d__dot--immediate {
    background: #8b5cf6;
  }

  .tarija-map-3d__dot--soon {
    background: #f5b342;
  }

  .tarija-map-3d__dot--planned {
    background: #10b981;
  }

  @media (max-width: 640px) {
    .tarija-map-3d {
      min-height: 390px;
    }

    .tarija-map-3d__toolbar {
      top: 12px;
      right: 12px;
      left: 12px;
      width: auto;
      padding: 9px 12px;
    }

    .tarija-map-3d__legend {
      gap: 10px;
      padding: 10px 12px;
    }

    .tarija-map-3d__label {
      max-width: 72px;
      padding: 2px 5px;
      font-size: 8.5px;
    }
  }
</style>
